<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="ModGrid_6133261.MainPage">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Label
           Text="Grid modificado con imagenes"
           HorizontalOptions="Center"
           VerticalOptions="Center"
           FontSize="Large"/>
        <Grid RowSpacing="10" ColumnSpacing="10">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
        <Image
            Source="chuchitos1.jpg"
            Grid.Row="0"
            Grid.Column="0"
            HeightRequest="150"
            WidthRequest="150"/>
        <Image
            Source="chuchitos2.jpg"
            Grid.Row="0"
            Grid.Column="1"
            HeightRequest="150"
            WidthRequest="150"/>
        <Image
            Source="chuchitos3.jpg"
            Grid.Row="1"
            Grid.Column="0"
            HeightRequest="150"
            WidthRequest="150"/>
        <Image
            Source="chuchitos4.jpg"
            Grid.Row="1"
            Grid.Column="1"
            HeightRequest="150"
            WidthRequest="150"/>
        </Grid>
        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
