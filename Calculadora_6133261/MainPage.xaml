<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Calculadora_6133261.MainPage">
    <ContentPage.Resources>
        <Style TargetType="Button">
            <Setter Property="BackgroundColor" Value="Purple" />
            <Setter Property="FontSize" Value="24" />
            <Setter Property="FontAttributes" Value="Bold" />
            <Setter Property="HorizontalOptions" Value="FillAndExpand" />
            <Setter Property="VerticalOptions" Value="FillAndExpand" />
            <Setter Property="Margin" Value="2" />
        </Style>
    </ContentPage.Resources>
    <ScrollView>
        <Grid RowDefinitions="Auto,1*,1*,1*,1*,1*" ColumnDefinitions="1*,1*,1*,1*">
            <Label x:Name="ResultLabel" Text="0" FontSize="36" HorizontalTextAlignment="End" VerticalTextAlignment="Center" Grid.Row="0" Grid.Column="0" Grid.ColumnSpan="4" />
            <Button Text="7" Grid.Row="1" Grid.Column="0" Clicked="Button_Clicked" />
            <Button Text="8" Grid.Row="1" Grid.Column="1" Clicked="Button_Clicked" />
            <Button Text="9" Grid.Row="1" Grid.Column="2" Clicked="Button_Clicked" />
            <Button Text="/" Grid.Row="1" Grid.Column="3" Clicked="Button_Clicked" />
            <Button Text="4" Grid.Row="2" Grid.Column="0" Clicked="Button_Clicked" />
            <Button Text="5" Grid.Row="2" Grid.Column="1" Clicked="Button_Clicked" />
            <Button Text="6" Grid.Row="2" Grid.Column="2" Clicked="Button_Clicked" />
            <Button Text="*" Grid.Row="2" Grid.Column="3" Clicked="Button_Clicked" />
            <Button Text="1" Grid.Row="3" Grid.Column="0" Clicked="Button_Clicked" />
            <Button Text="2" Grid.Row="3" Grid.Column="1" Clicked="Button_Clicked" />
            <Button Text="3" Grid.Row="3" Grid.Column="2" Clicked="Button_Clicked" />
            <Button Text="-" Grid.Row="3" Grid.Column="3" Clicked="Button_Clicked" />
            <Button Text="." Grid.Row="4" Grid.Column="0" Clicked="Button_Clicked" />
            <Button Text="0" Grid.Row="4" Grid.Column="1" Clicked="Button_Clicked" />
            <Button Text="C" Grid.Row="4" Grid.Column="2" Clicked="Button_Clicked" />
            <Button Text="+" Grid.Row="4" Grid.Column="3" Clicked="Button_Clicked" />
            <Button Text="=" Grid.Row="5" Grid.Column="4" Clicked="Button_Clicked" />
        </Grid>
    </ScrollView>
</ContentPage>
