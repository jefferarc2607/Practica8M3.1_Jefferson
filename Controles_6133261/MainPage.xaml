<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Controles_6133261.MainPage">

    <ScrollView>
        <StackLayout Spacing="20" Padding="10">

            <!-- BoxView -->
            <BoxView BackgroundColor="Black"
                     HeightRequest="200"/>

            <!-- Label -->
            <Label Text="XAMARIN" 
                   TextColor="Black"
                   FontAttributes="Bold"
                   FontSize="Large"
                   HorizontalTextAlignment="Center"/>

            <!-- Ellipse -->
            <Ellipse Fill="DarkRed"
                     Stroke="DarkGreen"
                     StrokeThickness="10"
                     HeightRequest="200"
                     HorizontalOptions="Center"
                     WidthRequest="200"/>

            <!-- Line -->
            <Line Stroke="Black"
                  X1="0"
                  Y1="0"
                  X2="100"
                  Y2="50"
                  StrokeThickness="10"/>

            <!-- Rectangle -->
            <Rectangle Fill="DarkRed"
                       Stroke="Black"
                       StrokeThickness="5"
                       HeightRequest="50"
                       HorizontalOptions="End"
                       WidthRequest="150"
                       RadiusX="10"
                       RadiusY="10"/>

            <!-- Polygon 1 -->
            <Polygon Fill="LightBlue"
                     Points="40,10 70,80 10,50"
                     Stroke="DarkBlue"
                     StrokeThickness="5"/>

            <!-- Polygon 2 -->
            <Polygon Fill="Yellow"
                     Points="40,10 70,80 10,50"
                     Stroke="Green"
                     StrokeDashArray="1,1"
                     StrokeDashOffset="6"
                     StrokeThickness="5"/>

            <!-- Polyline -->
            <Polyline Points="0, 0, 0, 144, 96, 150, 100, 0, 192, 0, 192, 96, 50, 96, 48, 192, 150, 200, 144, 48"
                      Fill="Blue"
                      Stroke="Red"
                      StrokeThickness="3"/>

            <!-- Path -->
            <Path Aspect="Uniform"
                  HorizontalOptions="Center"
                  Stroke="Black"
                  Data="M 10, 100 L 100, 100 100, 50"/>

            <!-- Border -->
            <Border Stroke="#c4b833"
                    StrokeThickness="4"
                    Background="#288098"
                    Padding="16,8"
                    HorizontalOptions="Center">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="48, 6, 0, 48"/>
                </Border.StrokeShape>
                <Label Text="Welcome to .NET MAUI!"
                       VerticalOptions="Center"
                       HorizontalOptions="Center"
                       TextColor="White"/>
            </Border>

            <!-- Frame -->
            <Border Margin="5"
                   BackgroundColor="Azure"
                   Padding="16">
                <Image Source="dotnet_bot.svg"/>
            </Border>

            <!-- WebView -->
            <WebView HeightRequest="500"
                     Source="https://www.google.com"/>

        </StackLayout>
    </ScrollView>


</ContentPage>
